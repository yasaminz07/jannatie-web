# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Azure OpenAI (server-side only — NEVER prefix with NEXT_PUBLIC_)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_MOSQUE_MONTHLY=
STRIPE_PRICE_SCHOOL_MONTHLY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Twilio (SMS — phone verification + friend reminders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OTP signing secret (any long random string — keep private)
OTP_SECRET=

# Gmail SMTP (App Password — generate at myaccount.google.com/apppasswords)
# GMAIL_USER is the sending Gmail address (e.g. jannatieteam@gmail.com)
# GMAIL_APP_PASSWORD is the 16-char app password (no spaces)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# GNews (free tier, 100 requests/day — Mosque & Islamic News feed)
# Get a free key at https://gnews.io
GNEWS_API_KEY=

# Resend (transactional emails — better deliverability than Gmail SMTP)
# Sign up free at resend.com → verify jannatie.com domain → create API key
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@jannatie.com

# Firebase Admin SDK (for branded password reset emails via Gmail SMTP)
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
# client_email from the downloaded JSON
FIREBASE_ADMIN_CLIENT_EMAIL=
# private_key from the downloaded JSON (paste the whole -----BEGIN PRIVATE KEY----- block)
FIREBASE_ADMIN_PRIVATE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://jannatie.com
